      "problem": "Given positive real numbers a = 4 and b = 4, what is the ratio of the arithmetic mean to the geometric mean of a and b?",
      "answer": "1.0",
      "source_code": "import random\n\nCONCEPT_TYPE = \"inequality.am_gm_product\"\nCONCEPT_GROUP = \"inequality\"\n\ndef generate(seed):\n    rng = random.Random(seed)\n\n    # Reduce numeric ranges for easier solvers, but preserve structure\n    a = rng.randint(1, 5)\n    b = rng.randint(1, 5)\n\n    # Given positive real numbers a and b, the AM-GM inequality states that:\n    # (a + b) / 2 ≥ sqrt(a * b)\n    # The equality holds if and only if a = b.\n    am_gm_ratio = (a + b) / (2 * (a * b) ** 0.5)\n\n    problem = (\n        f\"Given positive real numbers a = {a} and b = {b}, \"\n        f\"what is the ratio of the arithmetic mean to the geometric mean of a and b?\"\n    )\n\n    return problem, str(am_gm_ratio)"
    },
