      "problem": "8 people each write their name on a card. The cards are shuffled and redistributed. In how many redistributions do exactly 4 people receive their own card?",
      "answer": "630",
      "source_code": "import random\n\nCONCEPT_TYPE = \"combinatorics.derangement_fixed_points\"\nCONCEPT_GROUP = \"combinatorics\"\n\ndef generate(seed):\n    rng = random.Random(seed)\n\n    n = rng.randint(5, 8)\n    k = rng.randint(1, min(n, 4))\n\n    # Example of a combinatorial problem related to derangements with a specific number of fixed points\n    problem = (\n        f\"{n} people each write their name on a card. The cards are shuffled and redistributed. In how many redistributions do exactly {k} people receive their own card?\"\n    )\n\n    # Calculate the number of derangements\n    def derangement(n):\n        if n == 0:\n            return 1\n        if n == 1:\n            return 0\n        a, b = 1, 0\n        for k in range(2, n + 1):\n            a, b = b, (k - 1) * (a + b)\n        return b\n\n    # Calculate the number of ways to choose k people to have their own card\n    ways_to_choose_k = math.comb(n, k)\n\n    # Calculate the number of derangements of the remaining n - k people\n    derangements_of_remaining = derangement(n - k)\n\n    # The total number of ways to have exactly k people receive their own card\n    answer = ways_to_choose_k * derangements_of_remaining\n\n    return problem, str(answer)"
    },
